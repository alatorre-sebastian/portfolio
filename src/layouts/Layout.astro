---
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

const {
    title,
    description = "Professional SDET portfolio — Test automation, QA, and software development. Interactive Playwright Trace Viewer simulation.",
    ogImage = "/profile.png",
} = Astro.props;

const siteUrl = Astro.url.origin;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <!-- SEO -->
        <meta name="description" content={description} />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:image" content={`${siteUrl}${ogImage}`} />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    </head>
    <body class="bg-[#111] text-zinc-300 font-sans antialiased text-[13px] h-screen overflow-auto lg:overflow-hidden">
        <slot />
    </body>
</html>

<style is:global>
    body, html { height: 100%; margin: 0; }
    
    /* Global Tailwind UI Classes */
    .action-btn {
        @apply w-full text-left py-4 px-5 hover:bg-[#222] border-b border-zinc-800/50 flex gap-3 items-center transition-colors text-[13px];
        border-left: 2px solid transparent;
        transition: background-color 200ms ease, border-left-color 200ms ease;
    }
    .action-btn:hover {
        border-left-color: #3b82f6;
    }
    .active-btn {
        @apply bg-[#2563eb]/20 border-l-2 border-l-blue-500 text-white !important;
    }
    .time-label {
        @apply text-zinc-400 w-14 shrink-0 font-mono text-right text-[12px];
    }
    .detail-tab {
        @apply flex-1 px-2 py-2 text-zinc-500 hover:text-white border-b-2 border-b-transparent transition-colors;
    }
    .active-tab {
        @apply text-white font-bold border-b-blue-500 !important;
    }

    /* Simulated Playwright Locator Highlight */
    .playwright-highlight {
        @apply ring-2 ring-red-500 ring-offset-2 ring-offset-[#111] bg-red-500/10 rounded-sm relative;
    }
    .playwright-highlight::before {
        content: 'locator(...)';
        @apply absolute -top-5 left-0 bg-red-500 text-white text-[9px] px-1 py-0.5 rounded-t-sm font-mono whitespace-nowrap;
    }

    /* Estilo para el tooltip flotante del selector (ACTUALIZADO CON DESLIZAMIENTO) */
    .pw-tooltip {
        @apply fixed bg-zinc-950 border border-zinc-700 text-white font-mono text-[10px] px-2 py-1 rounded shadow-xl pointer-events-none z-50 opacity-0;
        transform: translate(-50%, -50%);
        transition: opacity 0.3s ease, transform 0.3s ease-out;
    }
    .pw-tooltip.visible {
        @apply opacity-100;
        transform: translate(-50%, -100%);
    }
    .pw-no-transition {
        transition: none !important;
    }

    /* Resaltado dinámico azul punteado al hacer hover dentro del content-area */
    #content-area [data-pw-selector]:hover {
        @apply outline outline-2 outline-dotted outline-blue-500 rounded-sm cursor-crosshair relative;
    }

    /* --- NUEVAS ANIMACIONES SUTILES --- */

    /* 1. Transición suave para el área central */
    #content-area {
        transition: opacity 0.15s ease-in-out;
    }
    .fade-out {
        opacity: 0;
    }

    /* 2. El "Punto de Acción" (Punto rojo que palpita simulando el click/hover de Playwright) */
    .pw-action-point {
        @apply absolute w-3 h-3 bg-red-500 border-2 border-white rounded-full z-40 pointer-events-none;
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
        animation: pw-pulse 1.5s infinite cubic-bezier(0.66, 0, 0, 1);
    }
    @keyframes pw-pulse {
        to {
            box-shadow: 0 0 0 15px rgba(239, 68, 68, 0);
        }
    }
</style>